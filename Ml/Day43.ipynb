   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import numpy as np\n",
    "#inputs\n",
    "\n",
    "inputs=torch.tensor(\n",
    "    [1.0,2.0,3.0]\n",
    ")\n",
    "\n",
    "neuron=nn.Linear(\n",
    "    in_features=3,\n",
    "    out_features=1\n",
    ")\n",
    "\n",
    "output=neuron(inputs)\n",
    "print(output)\n",
    "\n",
    "print(neuron.weight)\n",
    "print(neuron.bias)\n",
    "\n",
    "print(neuron.weight @ inputs + neuron.bias)"
   ]
